<UserControl x:Class="SlideDock.Views.SettingsMenuView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:controls="clr-namespace:SlideDock.Controls"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Border Background="#CC2D2D30"
                BorderBrush="#FF3E3E42"
                BorderThickness="1">
            <StackPanel Margin="20">
                <TextBlock Text="Configurações" 
                           Foreground="White" 
                           FontSize="24" 
                           FontWeight="Bold" 
                           Margin="0,0,0,20"/>

                <!-- Nova configuração: Sempre visível -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,10">
                    <TextBlock Text="Sempre visível"
                               Foreground="White"
                               FontSize="14"
                               VerticalAlignment="Center"
                               Margin="0,0,10,0"/>
                    <!-- ToggleButton customizado -->
                    <controls:ToggleSwitch IsChecked="{Binding IsAlwaysOnTop, Mode=TwoWay}" />
                </StackPanel>

                <!-- Conteúdo das configurações virá aqui -->
                <TextBlock Text="Em breve..." 
                           Foreground="LightGray" 
                           FontSize="18"/>

                <Button Content="Fechar" 
                        Width="100" Height="30" 
                        Margin="0,20,0,0" 
                        HorizontalAlignment="Left"
                        Command="{Binding CloseSettingsCommand}"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>

<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:local="clr-namespace:SlideDock.Controls">

    <Style TargetType="{x:Type local:ToggleSwitch}">
        <Setter Property="Width" Value="60"/>
        <Setter Property="Height" Value="30"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:ToggleSwitch}">
                    <Grid>
                        <!-- Fundo -->
                        <Border x:Name="SwitchBackground"
                                CornerRadius="15"
                                Background="#CCC"
                                BorderBrush="#999"
                                BorderThickness="1"/>

                        <!-- Botão deslizante -->
                        <Ellipse x:Name="SwitchKnob"
                                 Fill="White"
                                 Width="26"
                                 Height="26"
                                 Margin="2"
                                 HorizontalAlignment="Left"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="SwitchBackground" Property="Background" Value="#4CAF50"/>
                            <Setter TargetName="SwitchKnob" Property="HorizontalAlignment" Value="Right"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
